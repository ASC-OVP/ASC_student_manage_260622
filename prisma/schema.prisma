generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Academy {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                User[]
  students             Student[]
  classGroups          ClassGroup[]
  classLessons         ClassLesson[]
  classMemos           ClassMemo[]
  classGroupAssistants ClassGroupAssistant[]
  studentClasses       StudentClass[]
  counselingRecords    CounselingRecord[]
  clinicRecords        ClinicRecord[]
  questionRecords      QuestionRecord[]
  schoolScoreRecords   SchoolScoreRecord[]
  tasks                Task[]
  taskAssignees        TaskAssignee[]
  assistantWorkShifts  AssistantWorkShift[]
  calendarPrivateMemos CalendarPrivateMemo[]
  calendarEventMemos   CalendarEventMemo[]
  announcementMemos    AnnouncementMemo[]
  announcementReads    AnnouncementRead[]
  personalStickyMemos  PersonalStickyMemo[]
  messageTemplates     MessageTemplate[]
  messageJobs          MessageJob[]
  smsConsents          SmsConsent[]
  smsProviderLogs      SmsProviderLog[]
  smsProviderSettings  SmsProviderSetting[]
  omrUploads           OmrUpload[]
  exams                Exam[]
  examResults          ExamResult[]
  classTests           ClassTest[]
  studentTestScores    StudentTestScore[]
  attendanceRecords    AttendanceRecord[]
  assignmentRecords    AssignmentRecord[]
  scoreRecords         ScoreRecord[]
  recurringTasks       RecurringTask[]
  settings             AcademySetting[]
}

model AcademySetting {
  id        String   @id @default(uuid())
  academyId String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)

  @@unique([academyId, key])
  @@index([academyId])
}

model User {
  id           String   @id @default(uuid())
  academyId    String
  name         String
  loginId      String
  passwordHash String
  role         UserRole
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)

  teacherStudents          Student[]             @relation("StudentTeacher")
  assistantStudents        Student[]             @relation("StudentAssistant")
  ledClassGroups           ClassGroup[]          @relation("ClassGroupTeacher")
  assistedClassGroups      ClassGroup[]          @relation("ClassGroupAssistant")
  classGroupAssistantLinks ClassGroupAssistant[] @relation("ClassGroupAssistantUser")

  assignedTasks          Task[]              @relation("TaskAssignee")
  taskAssignments        TaskAssignee[]      @relation("TaskAssignmentUser")
  createdTasks           Task[]              @relation("TaskCreator")
  reviewTasks            Task[]              @relation("TaskReviewer")
  assignedRecurringTasks RecurringTask[]     @relation("RecurringTaskAssignee")
  createdRecurringTasks  RecurringTask[]     @relation("RecurringTaskCreator")
  taskStatusHistories    TaskStatusHistory[]
  taskSubmissions        TaskSubmission[]
  taskReviews            TaskReview[]
  taskChecklistItems     TaskChecklistItem[]

  memos                   StudentMemo[]
  classMemos              ClassMemo[]
  taskComments            TaskComment[]
  assistantWorkShifts     AssistantWorkShift[]  @relation("AssistantWorkShiftAssistant")
  createdWorkShifts       AssistantWorkShift[]  @relation("AssistantWorkShiftCreator")
  calendarPrivateMemos    CalendarPrivateMemo[]
  calendarEventMemos      CalendarEventMemo[]
  announcementMemos       AnnouncementMemo[]    @relation("AnnouncementMemoAuthor")
  announcementReads       AnnouncementRead[]
  personalStickyMemos     PersonalStickyMemo[]
  createdMessageTemplates MessageTemplate[]     @relation("MessageTemplateCreator")
  createdMessageJobs      MessageJob[]          @relation("MessageJobCreator")
  counselingRecords       CounselingRecord[]    @relation("CounselingOwner")
  clinicRecords           ClinicRecord[]        @relation("ClinicOwner")
  questionRecords         QuestionRecord[]      @relation("QuestionOwner")

  @@unique([academyId, loginId])
  @@index([academyId])
}

enum UserRole {
  ADMIN
  MANAGER
  TEACHER
  ASSISTANT
}

model Student {
  id        String @id @default(uuid())
  academyId String

  name         String
  phone        String?
  parentPhone  String?
  schoolName   String?
  grade        String?
  subject      String?
  currentLevel String?
  status       StudentStatus @default(ACTIVE)
  memo         String?

  teacherId   String?
  assistantId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  academy   Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  teacher   User?   @relation("StudentTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  assistant User?   @relation("StudentAssistant", fields: [assistantId], references: [id], onDelete: SetNull)

  memos              StudentMemo[]
  tasks              Task[]
  recurringTasks     RecurringTask[]
  studentClasses     StudentClass[]
  counselingRecords  CounselingRecord[]
  clinicRecords      ClinicRecord[]
  questionRecords    QuestionRecord[]
  schoolScoreRecords SchoolScoreRecord[]
  attendanceRecords  AttendanceRecord[]
  assignmentRecords  AssignmentRecord[]
  scoreRecords       ScoreRecord[]
  testScores         StudentTestScore[]
  omrUploads         OmrUpload[]
  examResults        ExamResult[]
  messageRecipients  MessageRecipient[]
  smsConsents        SmsConsent[]

  @@index([academyId])
  @@index([academyId, name])
  @@index([academyId, schoolName])
}

enum StudentStatus {
  ACTIVE
  PAUSED
  LEFT
  WATCH
}

model ClassGroup {
  id          String           @id @default(uuid())
  academyId   String
  name        String
  teacherId   String?
  assistantId String?
  subject     String?
  grade       String?
  startDate   String?
  endDate     String?
  daysOfWeek  String?
  startTime   String?
  endTime     String?
  room        String?
  schedule    String?
  description String?
  status      ClassGroupStatus @default(ACTIVE)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  academy   Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  teacher   User?   @relation("ClassGroupTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  assistant User?   @relation("ClassGroupAssistant", fields: [assistantId], references: [id], onDelete: SetNull)

  studentClasses  StudentClass[]
  classAssistants ClassGroupAssistant[]
  lessons         ClassLesson[]
  exams           Exam[]
  classTests      ClassTest[]
  testScores      StudentTestScore[]
  memos           ClassMemo[]
  tasks           Task[]
  recurringTasks  RecurringTask[]

  @@unique([academyId, name])
  @@index([academyId])
  @@index([teacherId])
  @@index([assistantId])
}

model ClassLesson {
  id           String   @id @default(uuid())
  academyId    String
  classGroupId String
  position     Int
  title        String
  lessonDate   String?
  startTime    String?
  endTime      String?
  memo         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  academy    Academy            @relation(fields: [academyId], references: [id], onDelete: Cascade)
  classGroup ClassGroup         @relation(fields: [classGroupId], references: [id], onDelete: Cascade)
  exams      Exam[]
  classTests ClassTest[]
  testScores StudentTestScore[]

  @@unique([classGroupId, position])
  @@index([academyId])
  @@index([classGroupId])
  @@index([academyId, lessonDate])
}

enum ClassGroupStatus {
  UPCOMING
  ACTIVE
  PAUSED
  ENDED
}

model ClassGroupAssistant {
  id           String   @id @default(uuid())
  academyId    String
  classGroupId String
  assistantId  String
  createdAt    DateTime @default(now())

  academy    Academy    @relation(fields: [academyId], references: [id], onDelete: Cascade)
  classGroup ClassGroup @relation(fields: [classGroupId], references: [id], onDelete: Cascade)
  assistant  User       @relation("ClassGroupAssistantUser", fields: [assistantId], references: [id], onDelete: Cascade)

  @@unique([classGroupId, assistantId])
  @@index([academyId])
  @@index([classGroupId])
  @@index([assistantId])
}

model StudentClass {
  id           String           @id @default(uuid())
  academyId    String
  studentId    String
  classGroupId String
  isPrimary    Boolean          @default(true)
  status       EnrollmentStatus @default(ACTIVE)
  joinedAt     String?
  leftAt       String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  academy    Academy    @relation(fields: [academyId], references: [id], onDelete: Cascade)
  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classGroup ClassGroup @relation(fields: [classGroupId], references: [id], onDelete: Cascade)

  @@unique([studentId, classGroupId])
  @@index([academyId])
  @@index([studentId])
  @@index([classGroupId])
}

enum EnrollmentStatus {
  ACTIVE
  PAUSED
  LEFT
}

model ClassMemo {
  id           String   @id @default(uuid())
  academyId    String
  classGroupId String
  writerId     String
  content      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  academy    Academy    @relation(fields: [academyId], references: [id], onDelete: Cascade)
  classGroup ClassGroup @relation(fields: [classGroupId], references: [id], onDelete: Cascade)
  writer     User       @relation(fields: [writerId], references: [id], onDelete: Cascade)

  @@index([academyId])
  @@index([classGroupId])
  @@index([writerId])
}

model StudentMemo {
  id          String   @id @default(uuid())
  studentId   String
  writerId    String
  type        MemoType @default(GENERAL)
  content     String
  isImportant Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  writer  User    @relation(fields: [writerId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([writerId])
}

enum MemoType {
  GENERAL
  STUDY
  ATTENDANCE
  ATTITUDE
  COUNSELING
  HOMEWORK
  CLINIC
  ETC
}

model CounselingRecord {
  id        String   @id @default(uuid())
  academyId String
  studentId String
  ownerId   String?
  date      String
  title     String   @default("?곷떞")
  content   String
  status    String   @default("DONE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  owner   User?   @relation("CounselingOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([academyId, date])
  @@index([studentId, date])
  @@index([ownerId])
}

model ClinicRecord {
  id        String   @id @default(uuid())
  academyId String
  studentId String
  ownerId   String?
  date      String
  title     String
  content   String?
  status    String   @default("TODO")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  owner   User?   @relation("ClinicOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([academyId, date])
  @@index([studentId, date])
  @@index([ownerId])
}

model QuestionRecord {
  id        String   @id @default(uuid())
  academyId String
  studentId String
  ownerId   String?
  date      String
  subject   String?
  content   String
  answer    String?
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  owner   User?   @relation("QuestionOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([academyId, date])
  @@index([studentId, date])
  @@index([ownerId])
}

model SchoolScoreRecord {
  id        String   @id @default(uuid())
  academyId String
  studentId String
  date      String?
  term      String
  examType  String
  subject   String
  score     Float?
  grade     String?
  memo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([academyId])
  @@index([studentId])
  @@index([studentId, term])
}

model AttendanceRecord {
  id        String @id @default(uuid())
  academyId String
  studentId String
  date      String

  status String  @default("PRESENT")
  memo   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([academyId, date])
  @@index([studentId, date])
}

model AssignmentRecord {
  id        String @id @default(uuid())
  academyId String
  studentId String
  date      String
  title     String @default("과제")

  status String  @default("UNCHECKED")
  score  Int?
  memo   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date, title])
  @@index([academyId, date])
  @@index([studentId, date])
}

model ScoreRecord {
  id        String @id @default(uuid())
  academyId String
  studentId String
  date      String
  title     String @default("테스트")

  score    Int?
  maxScore Int     @default(100)
  memo     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date, title])
  @@index([academyId, date])
  @@index([studentId, date])
}

model ClassTest {
  id            String        @id @default(uuid())
  academyId     String
  classGroupId  String
  classLessonId String?
  lessonPosition Int?
  name          String
  type          ClassTestType @default(SINGLE)
  subject       String?
  totalScore    Int?
  questionCount Int?
  templateType  OmrTemplateType @default(OTHER)
  active        Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  academy    Academy            @relation(fields: [academyId], references: [id], onDelete: Cascade)
  classGroup  ClassGroup   @relation(fields: [classGroupId], references: [id], onDelete: Cascade)
  classLesson ClassLesson? @relation(fields: [classLessonId], references: [id], onDelete: SetNull)
  exams       Exam[]
  scores     StudentTestScore[]

  @@index([academyId])
  @@index([classGroupId])
  @@index([classGroupId, active])
  @@index([classGroupId, type])
  @@index([classLessonId])
}

model StudentTestScore {
  id            String                 @id @default(uuid())
  academyId     String
  studentId     String
  classGroupId  String
  classTestId   String
  examId        String
  classLessonId String?
  score         Int?
  totalScore    Int?
  source        StudentTestScoreSource @default(MANUAL)
  omrResultId   String?                @unique
  memo          String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  academy     Academy      @relation(fields: [academyId], references: [id], onDelete: Cascade)
  student     Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classGroup  ClassGroup   @relation(fields: [classGroupId], references: [id], onDelete: Cascade)
  classTest   ClassTest    @relation(fields: [classTestId], references: [id], onDelete: Cascade)
  exam        Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  classLesson ClassLesson? @relation(fields: [classLessonId], references: [id], onDelete: SetNull)
  omrResult   ExamResult?  @relation(fields: [omrResultId], references: [id], onDelete: SetNull)

  @@unique([studentId, examId])
  @@index([academyId])
  @@index([studentId])
  @@index([classGroupId])
  @@index([classTestId])
  @@index([examId])
  @@index([source])
}

model Task {
  id          String   @id @default(uuid())
  academyId   String
  title       String
  description String?
  type        TaskType @default(OTHER)

  studentId       String?
  classGroupId    String?
  assigneeId      String
  creatorId       String
  reviewerId      String?
  recurringTaskId String?
  scheduledDate   String?

  status          TaskStatus   @default(TODO)
  priority        TaskPriority @default(NORMAL)
  color           String?
  startDate       DateTime?
  dueDate         DateTime?
  actualMinutes   Int?
  evidenceSummary String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  submittedAt DateTime?
  approvedAt  DateTime?
  rejectedAt  DateTime?
  completedAt DateTime?

  academy        Academy             @relation(fields: [academyId], references: [id], onDelete: Cascade)
  student        Student?            @relation(fields: [studentId], references: [id], onDelete: SetNull)
  classGroup     ClassGroup?         @relation(fields: [classGroupId], references: [id], onDelete: SetNull)
  assignee       User                @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: Cascade)
  creator        User                @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  reviewer       User?               @relation("TaskReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  recurringTask  RecurringTask?      @relation(fields: [recurringTaskId], references: [id], onDelete: SetNull)
  comments       TaskComment[]
  histories      TaskStatusHistory[]
  submissions    TaskSubmission[]
  reviews        TaskReview[]
  checklistItems TaskChecklistItem[]
  assignees      TaskAssignee[]

  @@unique([recurringTaskId, scheduledDate])
  @@index([academyId])
  @@index([assigneeId])
  @@index([studentId])
  @@index([classGroupId])
  @@index([reviewerId])
  @@index([recurringTaskId])
  @@index([scheduledDate])
}

model TaskAssignee {
  id         String   @id @default(uuid())
  academyId  String
  taskId     String
  assigneeId String
  color      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  academy  Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  task     Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assignee User    @relation("TaskAssignmentUser", fields: [assigneeId], references: [id], onDelete: Cascade)

  @@unique([taskId, assigneeId])
  @@index([academyId])
  @@index([taskId])
  @@index([assigneeId])
}

model AssistantWorkShift {
  id           String   @id @default(uuid())
  academyId    String
  assistantId  String
  workDate     String
  startTime    String
  endTime      String
  breakMinutes Int      @default(0)
  hourlyWage   Int      @default(0)
  status       String   @default("SCHEDULED")
  memo         String?
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  academy   Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  assistant User    @relation("AssistantWorkShiftAssistant", fields: [assistantId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("AssistantWorkShiftCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([academyId, workDate])
  @@index([assistantId, workDate])
  @@index([status])
}

model CalendarPrivateMemo {
  id        String   @id @default(uuid())
  academyId String
  userId    String
  date      String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([academyId, date])
}

model CalendarEventMemo {
  id        String   @id @default(uuid())
  academyId String
  eventKey  String
  eventType String
  eventDate String
  title     String?
  content   String
  writerId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  writer  User?   @relation(fields: [writerId], references: [id], onDelete: SetNull)

  @@unique([academyId, eventKey])
  @@index([academyId, eventDate])
  @@index([writerId])
}

model AnnouncementMemo {
  id        String               @id @default(uuid())
  academyId String
  authorId  String
  title     String
  content   String
  priority  AnnouncementPriority @default(NORMAL)
  isPinned  Boolean              @default(false)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  academy Academy            @relation(fields: [academyId], references: [id], onDelete: Cascade)
  author  User               @relation("AnnouncementMemoAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  reads   AnnouncementRead[]

  @@index([academyId, isPinned, createdAt])
  @@index([academyId, priority])
  @@index([authorId])
}

model AnnouncementRead {
  id             String   @id @default(uuid())
  academyId      String
  announcementId String
  userId         String
  readAt         DateTime @default(now())

  academy      Academy          @relation(fields: [academyId], references: [id], onDelete: Cascade)
  announcement AnnouncementMemo @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([academyId, userId])
  @@index([announcementId])
}

model PersonalStickyMemo {
  id        String   @id @default(uuid())
  academyId String
  userId    String
  content   String
  color     String   @default("#FEF3C7")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([academyId, userId, updatedAt])
  @@index([userId])
}

model MessageTemplate {
  id          String   @id @default(uuid())
  academyId   String
  name        String
  category    String   @default("ETC")
  targetType  String   @default("GUARDIAN")
  title       String?
  body        String
  variables   String?
  isMarketing Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  academy   Academy      @relation(fields: [academyId], references: [id], onDelete: Cascade)
  createdBy User?        @relation("MessageTemplateCreator", fields: [createdById], references: [id], onDelete: SetNull)
  jobs      MessageJob[]

  @@index([academyId, category])
  @@index([academyId, isActive])
  @@index([createdById])
}

model MessageJob {
  id           String    @id @default(uuid())
  academyId    String
  templateId   String?
  title        String
  targetType   String
  status       String    @default("PENDING")
  dryRun       Boolean   @default(true)
  totalCount   Int       @default(0)
  successCount Int       @default(0)
  failedCount  Int       @default(0)
  createdById  String
  scheduledAt  DateTime?
  sentAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  academy      Academy            @relation(fields: [academyId], references: [id], onDelete: Cascade)
  template     MessageTemplate?   @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdBy    User               @relation("MessageJobCreator", fields: [createdById], references: [id], onDelete: Cascade)
  recipients   MessageRecipient[]
  providerLogs SmsProviderLog[]

  @@index([academyId, createdAt])
  @@index([academyId, status])
  @@index([templateId])
  @@index([createdById])
}

model MessageRecipient {
  id                String    @id @default(uuid())
  jobId             String
  studentId         String?
  recipientType     String
  receiverName      String
  phone             String
  normalizedPhone   String
  messageText       String
  templateData      String?
  missingVariables  String?
  status            String    @default("PENDING")
  providerMessageId String?
  errorMessage      String?
  retried           Boolean   @default(false)
  sentAt            DateTime?
  createdAt         DateTime  @default(now())

  job          MessageJob       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  student      Student?         @relation(fields: [studentId], references: [id], onDelete: SetNull)
  providerLogs SmsProviderLog[]

  @@index([jobId])
  @@index([studentId])
  @@index([recipientType])
  @@index([normalizedPhone])
  @@index([status])
}

model SmsConsent {
  id                 String    @id @default(uuid())
  academyId          String
  studentId          String?
  recipientType      String
  phone              String
  normalizedPhone    String
  operationalAllowed Boolean   @default(true)
  marketingAllowed   Boolean   @default(false)
  optedOutAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  academy Academy  @relation(fields: [academyId], references: [id], onDelete: Cascade)
  student Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  @@unique([academyId, recipientType, normalizedPhone])
  @@index([academyId, studentId])
  @@index([normalizedPhone])
}

model SmsProviderLog {
  id              String   @id @default(uuid())
  academyId       String
  jobId           String?
  recipientId     String?
  provider        String
  requestPayload  String?
  responsePayload String?
  status          String
  errorMessage    String?
  createdAt       DateTime @default(now())

  academy   Academy           @relation(fields: [academyId], references: [id], onDelete: Cascade)
  job       MessageJob?       @relation(fields: [jobId], references: [id], onDelete: SetNull)
  recipient MessageRecipient? @relation(fields: [recipientId], references: [id], onDelete: SetNull)

  @@index([academyId, createdAt])
  @@index([jobId])
  @@index([recipientId])
  @@index([provider])
  @@index([status])
}

enum AnnouncementPriority {
  NORMAL
  IMPORTANT
  URGENT
}

model SmsProviderSetting {
  id                      String    @id @default(uuid())
  academyId               String
  provider                String    @default("SSODAA")
  apiKeyEncrypted         String?
  tokenKeyEncrypted       String?
  defaultSendPhone        String?
  unsubPhone              String?
  senderName              String?
  testReceiverPhone       String?
  isMarketingDefault      Boolean   @default(false)
  lastConnectionStatus    String?
  lastConnectionMessage   String?
  lastConnectionCheckedAt DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)

  @@unique([academyId, provider])
  @@index([academyId])
  @@index([provider])
}

model RecurringTask {
  id          String   @id @default(uuid())
  academyId   String
  title       String
  description String?
  type        TaskType @default(OTHER)

  assigneeId   String
  creatorId    String
  studentId    String?
  classGroupId String?

  priority       TaskPriority   @default(NORMAL)
  recurrenceType RecurrenceType @default(WEEKLY)
  daysOfWeek     String?
  dayOfMonth     Int?
  startDate      String
  endDate        String?
  dueTime        String?
  isActive       Boolean        @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  academy    Academy     @relation(fields: [academyId], references: [id], onDelete: Cascade)
  assignee   User        @relation("RecurringTaskAssignee", fields: [assigneeId], references: [id], onDelete: Cascade)
  creator    User        @relation("RecurringTaskCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  student    Student?    @relation(fields: [studentId], references: [id], onDelete: SetNull)
  classGroup ClassGroup? @relation(fields: [classGroupId], references: [id], onDelete: SetNull)
  tasks      Task[]

  @@index([academyId])
  @@index([assigneeId])
  @@index([creatorId])
  @@index([studentId])
  @@index([classGroupId])
  @@index([isActive])
}

enum RecurrenceType {
  DAILY
  WEEKLY
  MONTHLY
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  SUBMITTED
  REVIEW
  DONE
  REJECTED
  HOLD
  OVERDUE
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TaskType {
  STUDENT_CARE
  ATTENDANCE_CHECK
  ASSIGNMENT_CHECK
  SCORE_INPUT
  WRONG_ANSWER
  COUNSELING_PREP
  PARENT_CONTACT
  MATERIAL_UPLOAD
  CLINIC_ASSIGN
  OMR_GRADING
  OTHER
}

model TaskStatusHistory {
  id          String      @id @default(uuid())
  taskId      String
  fromStatus  TaskStatus?
  toStatus    TaskStatus
  changedById String
  memo        String?
  hasEvidence Boolean     @default(false)
  createdAt   DateTime    @default(now())

  task      Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  changedBy User @relation(fields: [changedById], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([changedById])
}

model TaskSubmission {
  id            String   @id @default(uuid())
  taskId        String
  submittedById String
  content       String
  evidenceType  String   @default("TEXT")
  fileUrl       String?
  actualMinutes Int?
  createdAt     DateTime @default(now())

  task        Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  submittedBy User @relation(fields: [submittedById], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([submittedById])
}

model TaskReview {
  id         String   @id @default(uuid())
  taskId     String
  reviewerId String
  decision   String
  comment    String?
  createdAt  DateTime @default(now())

  task     Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  reviewer User @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([reviewerId])
}

model TaskChecklistItem {
  id        String    @id @default(uuid())
  taskId    String
  title     String
  isDone    Boolean   @default(false)
  doneAt    DateTime?
  doneById  String?
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  task   Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  doneBy User? @relation(fields: [doneById], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([doneById])
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String
  writerId  String
  content   String
  createdAt DateTime @default(now())

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  writer User @relation(fields: [writerId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([writerId])
}

model OmrUpload {
  id                   String          @id @default(uuid())
  academyId            String
  studentId            String?
  examId               String?
  templateType         OmrTemplateType @default(OTHER)
  phoneLast8           String?
  phoneRecognizeStatus String          @default("WAITING")
  matchStatus          String          @default("NEEDS_PHONE")
  recognizeStatus      String          @default("WAITING")
  gradingStatus        String          @default("WAITING")
  fileName             String          @default("unknown")
  fileType             String?
  fileSize             Int             @default(0)
  filePath             String?
  previewImagePath     String?
  recognitionEngine    String?
  recognitionLog       String?
  memo                 String?
  status               String          @default("UPLOADED")
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  academy           Academy               @relation(fields: [academyId], references: [id], onDelete: Cascade)
  student           Student?              @relation(fields: [studentId], references: [id], onDelete: SetNull)
  exam              Exam?                 @relation(fields: [examId], references: [id], onDelete: SetNull)
  recognizedAnswers OmrRecognizedAnswer[]
  results           ExamResult[]

  @@index([academyId])
  @@index([studentId])
  @@index([examId])
}

model Exam {
  id             String          @id @default(uuid())
  academyId      String
  classGroupId   String?
  classTestId    String?
  classLessonId  String?
  lessonPosition Int?
  title          String
  subject        String?
  examDate       String?
  templateType   OmrTemplateType @default(OTHER)
  questionCount  Int
  totalScore     Int?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  academy       Academy            @relation(fields: [academyId], references: [id], onDelete: Cascade)
  classGroup    ClassGroup?        @relation(fields: [classGroupId], references: [id], onDelete: SetNull)
  classTest     ClassTest?         @relation(fields: [classTestId], references: [id], onDelete: SetNull)
  classLesson   ClassLesson?       @relation(fields: [classLessonId], references: [id], onDelete: SetNull)
  answerKeys    ExamAnswerKey[]
  questionMetas ExamQuestionMeta[]
  uploads       OmrUpload[]
  results       ExamResult[]
  testScores    StudentTestScore[]

  @@index([academyId])
  @@index([academyId, examDate])
  @@index([academyId, classGroupId])
  @@index([classTestId])
  @@index([classLessonId])
}

model ExamQuestionMeta {
  id                  String   @id @default(uuid())
  examId              String
  questionNo          Int
  primaryType         String?
  secondaryType       String?
  answerFormat        String?
  difficulty          String?
  section             String?
  learningGoal        String?
  achievementStandard String?
  tags                String?
  memo                String?
  omrMappingStatus    String   @default("UNMAPPED")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([examId, questionNo])
  @@index([examId])
  @@index([primaryType])
  @@index([difficulty])
  @@index([omrMappingStatus])
}

model ExamAnswerKey {
  id         String   @id @default(uuid())
  examId     String
  questionNo Int
  answer     String
  score      Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([examId, questionNo])
  @@index([examId])
}

model OmrRecognizedAnswer {
  id               String          @id @default(uuid())
  omrUploadId      String
  questionNo       Int
  recognizedAnswer String?
  correctedAnswer  String?
  finalAnswer      String?
  confidence       Float?
  status           OmrAnswerStatus @default(REVIEW_NEEDED)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  upload OmrUpload @relation(fields: [omrUploadId], references: [id], onDelete: Cascade)

  @@unique([omrUploadId, questionNo])
  @@index([omrUploadId])
}

model ExamResult {
  id                String   @id @default(uuid())
  academyId         String
  studentId         String
  examId            String
  omrUploadId       String?
  totalScore        Int      @default(0)
  maxScore          Int      @default(0)
  correctCount      Int      @default(0)
  wrongCount        Int      @default(0)
  blankCount        Int      @default(0)
  reviewNeededCount Int      @default(0)
  createdAt         DateTime @default(now())

  academy   Academy           @relation(fields: [academyId], references: [id], onDelete: Cascade)
  student   Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  exam      Exam              @relation(fields: [examId], references: [id], onDelete: Cascade)
  omrUpload OmrUpload?        @relation(fields: [omrUploadId], references: [id], onDelete: SetNull)
  items     ExamResultItem[]
  testScore StudentTestScore?

  @@index([academyId])
  @@index([studentId])
  @@index([examId])
  @@index([omrUploadId])
}

model ExamResultItem {
  id            String           @id @default(uuid())
  examResultId  String
  questionNo    Int
  studentAnswer String?
  correctAnswer String?
  isCorrect     Boolean          @default(false)
  status        ExamResultStatus @default(REVIEW_NEEDED)
  score         Int              @default(0)

  result ExamResult @relation(fields: [examResultId], references: [id], onDelete: Cascade)

  @@index([examResultId])
}

enum OmrTemplateType {
  KOREAN
  MATH
  INQUIRY
  ENGLISH
  OTHER
}

enum OmrAnswerStatus {
  RECOGNIZED
  BLANK
  MULTIPLE
  REVIEW_NEEDED
  MANUAL
}

enum ExamResultStatus {
  CORRECT
  WRONG
  BLANK
  MULTIPLE
  REVIEW_NEEDED
}

enum ClassTestType {
  REGULAR
  SINGLE
}

enum StudentTestScoreSource {
  MANUAL
  OMR
}
